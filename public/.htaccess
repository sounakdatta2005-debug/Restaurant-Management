# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /restaurant-management/public/
    
    # Remove trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+?)/?$ $1 [L]
    
    # Rewrite all requests to index.php except for existing files/directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/restaurant-management/public/css/
    RewriteCond %{REQUEST_URI} !^/restaurant-management/public/js/
    RewriteCond %{REQUEST_URI} !^/restaurant-management/public/assets/
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# Disable directory listing
Options -Indexes

# Set proper charset
AddDefaultCharset UTF-8

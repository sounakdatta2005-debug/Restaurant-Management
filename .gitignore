# Restaurant Management System - .gitignore

# Environment configuration
.env
.env.local
.env.*.local

# IDE & Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# PHP
*.php.bak
*.php~
composer.lock

# Logs
logs/
*.log
npm-debug.log
yarn-debug.log
yarn-error.log

# Temporary files
tmp/
temp/
cache/
*.tmp

# Database
*.sql.bak
*.sql~
database.sqlite
database.sqlite-wal
database.sqlite-shm

# Sessions
sessions/
session_data/

# Uploads
uploads/
tmp_uploads/
public/uploads/

# Dependencies
node_modules/
vendor/
composer.lock

# Build files
dist/
build/
out/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# Configuration overrides (but keep examples)
config/database.php.local
config/config.local.php

# Testing
coverage/
.phpunit.result.cache
phpunit.xml.backup

# Miscellaneous
.directory
.vscode-server/
.remote/

# Sensitive data
config/secrets.php
config/api-keys.php
private_keys/

# Package managers
package-lock.json
yarn.lock
